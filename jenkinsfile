pipeline {
    agent any
     environment {
        SCANNER_HOME = tool 'sonarqube'
    }
    stages {
        stage('git checkout') {
            steps {
             git 'https://github.com/Syed00011/Java-Springboot.git'
            }
        }
         stage('compile') {
            steps {
              bat 'mvn compile'
            }
        }
        stage('package') {
            steps {
              bat 'mvn install'
            }
        }
         stage('docker build') {
            steps {
             script {
                  {
                    bat 'docker build -t ci-cd .'
                  }
              }
            }
        }
         stage('docker push') {
            steps {
             script {
                withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                    sh 'docker tag ci-cd sushmagowda321/dev:1.0'
                    sh 'docker push sushmagowda321/dev:1.0'
                  }
              }
            }
         }    
        stage('docker container') {
            steps {
             script {
                   withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                    sh 'docker run -itd --name ci-cd-container -p 57:8080 ci-cd'
                  }
              }
            }
        }
        stage('docker compose') {
            steps {
             script {
                 withDockerRegistry(credentialsId: 'docker-cred', toolName: 'docker') {
                    sh 'docker-compose up -d'
                  }
              }
            }
        }

    }	
 
    post {
        always {
            echo 'slack Notification.'
        }
    }
}
